[mysqld]
server-id = 2
log-bin = mysql-bin
binlog_format = ROW
gtid_mode = ON
enforce_gtid_consistency = ON
log_slave_updates = ON

# slave 默认只读（注意：不能用 super_read_only，会阻止 docker init 的 root 账号创建和 init.sql 执行）
read_only = ON

# relay log（slave 接收 master 二进制日志的中转文件）
relay_log = mysql-relay-bin

default_authentication_plugin = mysql_native_password
